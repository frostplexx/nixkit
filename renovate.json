{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "reviewers": ["frostplexx", "ojsef39"],
  "extends": ["config:recommended"],
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/flake-review\\.yml$/"],
      "matchStrings": ["flake-review-ref: \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "ojsef39/flake-review",
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["ojsef39/flake-review"],
      "groupName": "flake-review"
    },
    {
      "matchManagers": ["nix", "nix-update"],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
